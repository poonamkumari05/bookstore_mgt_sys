generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model users {
  id         Int        @id @default(autoincrement())
  name       String     @db.VarChar(100)
  email      String     @unique @db.VarChar(100)
  password   String     @db.VarChar(255)
  role       users_role
  created_at DateTime?  @default(now())

  carts     carts?
  orders    orders[]
  addresses addresses[] // ✅ FIX
}

model addresses {
  address_id Int    @id @default(autoincrement())
  user_id    Int
  city       String @db.VarChar(100)
  state      String @db.VarChar(100)
  pincode    String @db.VarChar(10)

  user   users    @relation(fields: [user_id], references: [id])
  orders orders[]

  @@index([user_id])
}

model books {
  book_id    Int       @id @default(autoincrement())
  book_name  String    @db.VarChar(200)
  price      Decimal   @db.Decimal(10, 2)
  stock      Int
  created_at DateTime? @default(now())

  cart_items   cart_items[]
  order_items  order_items[] // ✅ FIX
  book_authors book_authors[] // ✅ FIX
}

model authors {
  author_id   Int     @id @default(autoincrement())
  author_name String  @db.VarChar(100)
  email       String? @unique

  book_authors book_authors[] // ✅ FIX
}

model book_authors {
  book_id   Int
  author_id Int

  book   books   @relation(fields: [book_id], references: [book_id])
  author authors @relation(fields: [author_id], references: [author_id])

  @@id([book_id, author_id])
}

model orders {
  order_id     Int            @id @default(autoincrement())
  user_id      Int
  address_id   Int
  status       orders_status? @default(pending)
  total_amount Decimal?       @default(0.00)
  created_at   DateTime       @default(now())

  user        users         @relation(fields: [user_id], references: [id])
  address     addresses     @relation(fields: [address_id], references: [address_id])
  order_items order_items[]
  payments    payments[]
}

model order_items {
  order_item_id Int     @id @default(autoincrement())
  order_id      Int
  book_id       Int
  quantity      Int
  price         Decimal @db.Decimal(10, 2)

  order orders @relation(fields: [order_id], references: [order_id])
  book  books  @relation(fields: [book_id], references: [book_id])

  @@index([order_id])
  @@index([book_id])
}

model payments {
  payment_id     Int                      @id @default(autoincrement())
  order_id       Int
  amount         Decimal
  payment_method payments_payment_method
  payment_status payments_payment_status? @default(pending)
  payment_date   DateTime                 @default(now())

  order orders @relation(fields: [order_id], references: [order_id])

  @@index([order_id])
}

model carts {
  cart_id Int @id @default(autoincrement())
  user_id Int @unique

  user       users        @relation(fields: [user_id], references: [id])
  cart_items cart_items[]
}

model cart_items {
  cart_item_id Int @id @default(autoincrement())
  cart_id      Int
  book_id      Int
  quantity     Int

  cart carts @relation(fields: [cart_id], references: [cart_id])
  book books @relation(fields: [book_id], references: [book_id])

  @@index([book_id])
  @@index([cart_id])
}

enum users_role {
  admin
  consumer
}

enum orders_status {
  pending
  shipped
  delivered
  cancelled
}

enum payments_payment_method {
  card
  upi
  cod
}

enum payments_payment_status {
  pending
  completed
  failed
}
